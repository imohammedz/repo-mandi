NEXT_PUBLIC_MSG91_WIDGET_ID=366579704a4f393038343731
NEXT_PUBLIC_MSG91_WIDGET_TOKEN=your_msg91_widget_token
MSG91_AUTH_KEY=your_msg91_auth_key
# Comma-separated E.164 numbers authorized for admin login
ADMIN_PHONE_NUMBERS=+1XXXXXXXXXX,+91XXXXXXXXXX

DATABASE_URL=postgresql://username:password@host:5432/database
SESSION_SECRET=replace_with_a_long_random_secret
# Generate one with: openssl rand -base64 32
# Optional session TTL in days (default 14)
SESSION_TTL_DAYS=14

# Supabase — required for photo uploads
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# Storage bucket for vehicle images (default: vehicle-images)
SUPABASE_STORAGE_BUCKET=vehicle-images

# ─── OTP Provider ─────────────────────────────────────────────────────────────
# Active OTP provider is managed at runtime via Admin Settings (stored in
# platform_settings table). Default when no DB row exists: MSG91_SMS
# Allowed values: MSG91_SMS | WHATSAPP

# WhatsApp OTP — Meta WhatsApp Cloud API
# Required when OTP_PROVIDER=WHATSAPP (Meta WhatsApp Cloud API)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TEMPLATE_NAME=otp_login
WHATSAPP_TEMPLATE_LANGUAGE=en_US

# WhatsApp OTP — MSG91 WhatsApp (alternative to Meta API)
# Uncomment and fill if using MSG91 WhatsApp instead of Meta WhatsApp Cloud API
# MSG91_WHATSAPP_AUTH_KEY=
# MSG91_WHATSAPP_TEMPLATE_ID=
# MSG91_WHATSAPP_SENDER_ID=
